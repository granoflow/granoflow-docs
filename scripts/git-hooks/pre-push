#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(git rev-parse --show-toplevel 2>/dev/null || true)"
if [[ -z "$ROOT_DIR" ]]; then
  ROOT_DIR="$(cd "$(dirname "$0")/../.." && pwd)"
fi
cd "$ROOT_DIR"

if ! command -v node >/dev/null 2>&1; then
  echo "[pre-push] Reject push: node is required for granoflow-docs AI legal review."
  exit 1
fi

echo "[pre-push] Running granoflow-docs AI legal review ..."
node scripts/legal_push_review.mjs "$@"

